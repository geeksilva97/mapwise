<div data-controller="playback"
     data-playback-map-id-value="<%= map.id %>">
  <div class="space-y-4">
    <div>
      <label class="block text-xs font-medium text-gray-500 mb-1">Vehicle</label>
      <select data-playback-target="vehicleSelect"
              class="block w-full rounded-lg border-gray-300 bg-gray-50 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20">
        <option value="">Select a vehicle...</option>
        <% vehicles.each do |vehicle| %>
          <option value="<%= vehicle.id %>"><%= vehicle.name %></option>
        <% end %>
      </select>
    </div>

    <div class="grid grid-cols-2 gap-2">
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">From</label>
        <input type="datetime-local" data-playback-target="fromInput"
               value="<%= 24.hours.ago.strftime('%Y-%m-%dT%H:%M') %>"
               class="block w-full rounded-lg border-gray-300 bg-gray-50 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20">
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">To</label>
        <input type="datetime-local" data-playback-target="toInput"
               value="<%= Time.current.strftime('%Y-%m-%dT%H:%M') %>"
               class="block w-full rounded-lg border-gray-300 bg-gray-50 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20">
      </div>
    </div>

    <div>
      <label class="block text-xs font-medium text-gray-500 mb-1">Speed</label>
      <select data-playback-target="speedSelect"
              class="block w-full rounded-lg border-gray-300 bg-gray-50 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20">
        <option value="1">1x</option>
        <option value="2">2x</option>
        <option value="5" selected>5x</option>
        <option value="10">10x</option>
      </select>
    </div>

    <div class="flex gap-2">
      <button type="button" data-action="click->playback#load"
              class="flex-1 rounded-lg px-3 py-2 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium cursor-pointer">
        Load
      </button>
      <button type="button" data-action="click->playback#playPause" data-playback-target="playBtn"
              disabled
              class="rounded-lg px-3 py-2 border border-gray-300 hover:bg-gray-50 text-sm font-medium cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed">
        Play
      </button>
      <button type="button" data-action="click->playback#stop" data-playback-target="stopBtn"
              disabled
              class="rounded-lg px-3 py-2 border border-gray-300 hover:bg-gray-50 text-sm font-medium cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed">
        Stop
      </button>
    </div>

    <div data-playback-target="progressContainer" class="hidden">
      <div class="w-full bg-gray-200 rounded-full h-1.5">
        <div data-playback-target="progressBar" class="bg-blue-600 h-1.5 rounded-full transition-all" style="width: 0%"></div>
      </div>
      <p data-playback-target="progressLabel" class="text-xs text-gray-400 mt-1">0 / 0 points</p>
    </div>
  </div>
</div>
