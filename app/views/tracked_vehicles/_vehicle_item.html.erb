<div id="vehicle_<%= vehicle.id %>"
     data-controller="vehicle-item"
     data-vehicle-item-map-id-value="<%= map.id %>"
     data-vehicle-item-vehicle-id-value="<%= vehicle.id %>"
     data-vehicle-item-has-planned-path-value="<%= vehicle.planned_path.present? %>">
  <div data-vehicle-item-target="display">
    <%# Main row %>
    <div class="flex items-center justify-between px-3 py-2 rounded-md hover:bg-gray-50 group cursor-pointer"
         data-action="click->vehicle-item#toggleDetails">
      <div class="flex items-center gap-2 min-w-0">
        <span class="w-3 h-3 rounded-full shrink-0 <%= vehicle.active? ? '' : 'opacity-40' %>"
              style="background-color: <%= vehicle.color %>"></span>
        <span class="text-sm font-medium truncate <%= vehicle.active? ? '' : 'text-gray-400' %>"><%= vehicle.name %></span>
      </div>
      <div class="flex items-center gap-1.5 shrink-0">
        <% unless vehicle.active? %>
          <span class="text-xs text-gray-400">Inactive</span>
        <% end %>
        <svg data-vehicle-item-target="chevron" class="h-4 w-4 text-gray-400 transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
        </svg>
      </div>
    </div>

    <%# Expanded details %>
    <div data-vehicle-item-target="details" class="hidden px-3 pb-3 space-y-3">
      <%# Webhook URL %>
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Webhook URL</label>
        <div class="flex gap-1">
          <input type="text" readonly
                 data-vehicle-item-target="webhookUrl"
                 value="<%= webhook_tracking_url(vehicle.webhook_token) %>"
                 class="block w-full rounded-md border border-gray-300 bg-gray-50 px-2 py-1 text-xs text-gray-600 font-mono">
          <button type="button" data-action="click->vehicle-item#copyWebhookUrl"
                  class="shrink-0 rounded-md px-2 py-1 border border-gray-300 hover:bg-gray-50 text-xs font-medium cursor-pointer">
            Copy
          </button>
        </div>
      </div>

      <%# Info %>
      <div class="text-xs text-gray-500 space-y-1">
        <p>Color: <span class="inline-block w-3 h-3 rounded align-middle" style="background-color: <%= vehicle.color %>"></span> <%= vehicle.color %></p>
        <% if vehicle.deviation_threshold_meters %>
          <p>Deviation threshold: <%= vehicle.deviation_threshold_meters %>m</p>
        <% end %>
        <p>Planned path: <%= vehicle.planned_path.present? ? "Set" : "Not set" %></p>
        <% if (last = vehicle.last_tracking_point) %>
          <p>Last seen: <%= time_ago_in_words(last.recorded_at) %> ago (<%= last.lat.round(4) %>, <%= last.lng.round(4) %>)</p>
        <% end %>
        <p>Points: <%= vehicle.tracking_points.count %></p>
      </div>

      <%# Actions %>
      <div class="flex flex-wrap gap-1.5">
        <button type="button" data-action="click->vehicle-item#toggleActive"
                class="rounded-md px-2 py-1 border border-gray-300 hover:bg-gray-50 text-xs font-medium cursor-pointer">
          <%= vehicle.active? ? "Deactivate" : "Activate" %>
        </button>
        <button type="button" data-action="click->vehicle-item#drawPlannedPath"
                class="rounded-md px-2 py-1 border border-gray-300 hover:bg-gray-50 text-xs font-medium cursor-pointer">
          Draw Path
        </button>
        <% if vehicle.tracking_points.any? %>
          <button type="button" data-action="click->vehicle-item#clearPoints"
                  class="rounded-md px-2 py-1 border border-gray-300 hover:bg-gray-50 text-xs font-medium text-amber-600 cursor-pointer">
            Clear History
          </button>
        <% end %>
        <button type="button" data-action="click->vehicle-item#editVehicle"
                class="rounded-md px-2 py-1 border border-gray-300 hover:bg-gray-50 text-xs font-medium cursor-pointer">
          Edit
        </button>
        <button type="button" data-action="click->vehicle-item#deleteVehicle"
                class="rounded-md px-2 py-1 border border-red-200 hover:bg-red-50 text-xs font-medium text-red-600 cursor-pointer">
          Delete
        </button>
      </div>

      <%# Delete confirm %>
      <div data-vehicle-item-target="confirmDelete" class="hidden flex items-center justify-between bg-red-50 rounded-md px-3 py-2">
        <span class="text-sm text-red-700 font-medium">Delete vehicle?</span>
        <div class="flex gap-2">
          <button data-action="click->vehicle-item#cancelDelete"
                  class="text-xs font-medium text-gray-600 hover:text-gray-800 cursor-pointer">Cancel</button>
          <button data-action="click->vehicle-item#confirmDeleteVehicle"
                  class="text-xs font-medium text-white bg-red-600 hover:bg-red-500 rounded-md px-2.5 py-1 cursor-pointer">Delete</button>
        </div>
      </div>
    </div>
  </div>
</div>
