<div data-controller="vehicle-editor"
     data-vehicle-editor-map-id-value="<%= map.id %>">
  <div class="flex items-center justify-between mb-4">
    <h2 class="font-bold text-lg">Vehicles (<span data-vehicle-editor-target="count"><%= map.tracked_vehicles.count %></span>)</h2>
    <button data-action="click->vehicle-editor#showNewForm"
            class="rounded-md px-3 py-1.5 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium cursor-pointer">
      + Add
    </button>
  </div>

  <div id="vehicle_form_container">
    <turbo-frame id="vehicle_form"></turbo-frame>
  </div>

  <div id="vehicles_list" class="space-y-1">
    <% map.tracked_vehicles.ordered.each do |vehicle| %>
      <%= render "tracked_vehicles/vehicle_item", vehicle: vehicle, map: map %>
    <% end %>
  </div>

  <% if map.tracked_vehicles.empty? %>
    <p id="vehicles_empty" class="text-sm text-gray-400 mt-2">Add vehicles to start tracking.</p>
  <% end %>

  <div class="mt-6 border-t border-gray-200 pt-4">
    <%= link_to tracking_map_path(map), class: "inline-flex items-center gap-2 rounded-lg px-3 py-2 bg-green-600 hover:bg-green-500 text-white text-sm font-medium w-full justify-center cursor-pointer", target: "_blank" do %>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
      </svg>
      Open Tracking Page
    <% end %>
  </div>
</div>
