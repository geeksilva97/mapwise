<div id="layer_<%= layer.id %>"
     data-controller="layer-item"
     data-layer-item-map-id-value="<%= layer.map_id %>"
     data-layer-item-layer-id-value="<%= layer.id %>">

  <%# Display row %>
  <div data-layer-item-target="display" class="flex items-center justify-between px-3 py-2 rounded-md hover:bg-gray-50 group">
    <div class="flex items-center gap-2 min-w-0">
      <span data-layer-item-target="displayDot" class="w-3 h-3 rounded border shrink-0" style="background-color: <%= layer.fill_color %>; border-color: <%= layer.stroke_color %>"></span>
      <span data-layer-item-target="displayName" class="text-sm font-medium truncate"><%= layer.name %></span>
      <span class="text-xs text-gray-400 capitalize"><%= layer.layer_type %></span>
    </div>
    <div class="flex items-center gap-1.5 shrink-0 opacity-0 group-hover:opacity-100">
      <button type="button"
              data-action="click->marker-editor#toggleLayerVisibility"
              data-layer-id="<%= layer.id %>"
              class="p-1 rounded hover:bg-gray-200 transition-colors"
              title="<%= layer.visible? ? 'Hide' : 'Show' %>">
        <% if layer.visible? %>
          <svg class="h-3.5 w-3.5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        <% else %>
          <svg class="h-3.5 w-3.5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
          </svg>
        <% end %>
      </button>
      <button type="button"
              data-action="click->layer-item#toggle"
              class="p-1 rounded hover:bg-gray-200 transition-colors"
              title="Edit layer">
        <svg class="h-3.5 w-3.5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125" />
        </svg>
      </button>
      <button type="button"
              data-action="click->marker-editor#deleteLayer"
              data-layer-id="<%= layer.id %>"
              class="p-1 rounded hover:bg-red-100 transition-colors"
              title="Delete layer">
        <svg class="h-3.5 w-3.5 text-gray-400 hover:text-red-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
        </svg>
      </button>
    </div>
  </div>

  <%# Inline edit form (collapsed by default) %>
  <div data-layer-item-target="form" class="hidden px-2 pb-2">
    <div class="border rounded-lg p-3 bg-gray-50 space-y-3">
      <div>
        <label class="block text-xs font-medium text-gray-700">Name</label>
        <input type="text"
               data-layer-item-target="name"
               value="<%= layer.name %>"
               class="block shadow-sm rounded-md border border-gray-300 focus:outline-blue-600 px-3 py-1.5 mt-1 w-full text-sm">
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs font-medium text-gray-700">Stroke</label>
          <input type="color"
                 data-layer-item-target="strokeColor"
                 value="<%= layer.stroke_color || '#3B82F6' %>"
                 class="h-8 w-full rounded-md border border-gray-300 cursor-pointer mt-1">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-700">Fill</label>
          <input type="color"
                 data-layer-item-target="fillColor"
                 value="<%= layer.fill_color || '#3B82F6' %>"
                 class="h-8 w-full rounded-md border border-gray-300 cursor-pointer mt-1">
        </div>
      </div>
      <div class="flex gap-2">
        <button type="button"
                data-action="click->layer-item#save"
                class="rounded-md px-3 py-1.5 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium cursor-pointer">
          Save
        </button>
        <button type="button"
                data-action="click->layer-item#toggle"
                class="rounded-md px-3 py-1.5 border border-gray-300 hover:bg-gray-50 text-sm font-medium cursor-pointer">
          Cancel
        </button>
      </div>
    </div>
  </div>
</div>
