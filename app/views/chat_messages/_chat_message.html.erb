<div class="flex mb-3 <%= message.role == 'user' ? 'justify-end' : 'justify-start' %>">
  <div class="max-w-[85%] rounded-2xl px-4 py-2.5 text-sm leading-relaxed
    <%= message.role == 'user' ? 'rounded-br-sm bg-blue-600 text-white' : 'rounded-bl-sm bg-gray-100 text-gray-800' %>">
    <%= simple_format(message.content, {}, wrapper_tag: "span") %>
  </div>
</div>
