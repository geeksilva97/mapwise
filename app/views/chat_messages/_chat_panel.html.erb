<div data-controller="chat" data-chat-map-id-value="<%= map.id %>" class="flex flex-col h-full">
  <%# Header with clear button %>
  <% if map.chat_messages.any? %>
    <div class="flex items-center justify-end px-4 pt-2">
      <button type="button"
              data-action="click->confirm-dialog#open"
              data-confirm-title="Clear chat"
              data-confirm-message="Clear all chat messages? This cannot be undone."
              data-confirm-form="#clear_chat_<%= map.id %>"
              class="text-xs text-gray-400 hover:text-red-500 transition-colors cursor-pointer">
        Clear chat
      </button>

      <%= form_with url: clear_map_chat_messages_path(map), method: :delete, id: "clear_chat_#{map.id}", class: "hidden" do %>
      <% end %>
    </div>
  <% end %>

  <%# Message history %>
  <div data-chat-target="messages" id="chat_messages"
       class="flex-1 overflow-y-auto p-4 space-y-0">
    <% map.chat_messages.ordered.each do |message| %>
      <%= render "chat_messages/chat_message", message: message %>
    <% end %>

    <% if map.chat_messages.empty? %>
      <div id="chat_empty_state" class="text-center text-gray-400 mt-8">
        <svg class="h-10 w-10 mx-auto mb-3 text-gray-300" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />
        </svg>
        <p class="text-sm font-medium">AI Map Assistant</p>
        <p class="text-xs mt-1">Describe what you want to add to your map</p>
      </div>
    <% end %>
  </div>

  <%# Input area %>
  <div class="border-t bg-white p-3">
    <form data-action="submit->chat#submit" class="flex gap-2">
      <input type="text" placeholder="Describe what you want..."
        data-chat-target="input"
        autocomplete="off"
        class="flex-1 rounded-lg border border-gray-300 bg-gray-50 px-3 py-2 text-sm focus:bg-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none">
      <button type="submit" data-chat-target="submitButton"
        class="rounded-lg bg-brand-600 hover:bg-brand-500 text-white px-4 py-2 text-sm font-medium transition-colors cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed">
        Send
      </button>
    </form>
  </div>
</div>
