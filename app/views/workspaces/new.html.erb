<div class="max-w-lg mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">New Workspace</h1>

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
    <%= form_with model: @workspace, url: workspaces_path do |form| %>
      <% if @workspace.errors.any? %>
        <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
          <ul class="list-disc ml-5">
            <% @workspace.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-4">
        <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :name, required: true, placeholder: "e.g. Marketing Team",
            class: "block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2 text-sm focus:bg-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none" %>
      </div>

      <div class="flex items-center gap-3">
        <%= form.submit "Create Workspace", class: "rounded-lg px-4 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium cursor-pointer transition-colors" %>
        <%= link_to "Cancel", root_path, class: "text-sm text-gray-600 hover:text-gray-900" %>
      </div>
    <% end %>
  </div>
</div>
