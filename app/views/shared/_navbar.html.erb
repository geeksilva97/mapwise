<nav class="sticky top-0 z-50 bg-white border-b border-gray-200" data-controller="navbar">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <%# Logo %>
      <%= link_to root_path, class: "flex items-center gap-2 text-gray-900 hover:text-gray-700" do %>
        <svg class="h-7 w-7 text-brand-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
        </svg>
        <span class="text-lg font-bold"><%= app_name %></span>
      <% end %>

      <% if authenticated? %>
        <%# Desktop username dropdown %>
        <div class="hidden sm:flex items-center relative">
          <button data-action="click->navbar#toggleDropdown" class="flex items-center gap-1 rounded-lg px-3 py-1.5 text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 cursor-pointer">
            <%= Current.user.name %>
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </button>

          <div data-navbar-target="dropdown" class="hidden absolute right-0 top-full mt-1 w-64 bg-white rounded-lg border border-gray-200 shadow-lg py-1 z-50">
            <%# Workspace switcher %>
            <% if Current.user.workspaces.count > 1 %>
              <div class="px-4 py-2">
                <p class="text-xs font-medium text-gray-400 uppercase tracking-wider">Workspaces</p>
              </div>
              <% Current.user.workspaces.each do |ws| %>
                <% if ws == current_workspace %>
                  <div class="flex items-center gap-2 px-4 py-2 text-sm text-brand-700 bg-brand-50">
                    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <%= ws.name %>
                  </div>
                <% else %>
                  <%= button_to ws.name, switch_workspace_path(ws), method: :post,
                      class: "w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 cursor-pointer pl-10" %>
                <% end %>
              <% end %>
              <div class="border-t border-gray-200 my-1"></div>
            <% end %>
            <%= link_to "My Maps", root_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" %>
            <% if current_workspace %>
              <%= link_to "Workspace Settings", workspace_path(current_workspace), class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" %>
            <% end %>
            <%= link_to "New Workspace", new_workspace_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" %>
            <%= link_to "Settings", settings_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" %>
            <div class="border-t border-gray-200 my-1"></div>
            <%= button_to "Sign out", session_path, method: :delete,
                class: "w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 cursor-pointer" %>
          </div>
        </div>
      <% else %>
        <div class="hidden sm:flex items-center gap-3">
          <%= link_to "Sign in", new_session_path,
              class: "rounded-lg px-3 py-2 text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50" %>
          <%= link_to "Sign up", new_registration_path,
              class: "rounded-lg px-3.5 py-2 text-sm font-medium bg-brand-600 text-white hover:bg-brand-500" %>
        </div>
      <% end %>

      <%# Mobile hamburger %>
      <button data-action="click->navbar#toggle" class="sm:hidden p-2 rounded-lg text-gray-500 hover:text-gray-700 hover:bg-gray-50">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </div>

  <%# Mobile menu %>
  <div class="hidden sm:hidden border-t border-gray-200" data-navbar-target="menu">
    <div class="px-4 py-3 space-y-1">
      <% if authenticated? %>
        <% if current_workspace %>
          <span class="block px-3 py-1 text-xs font-medium text-gray-400 uppercase tracking-wider"><%= current_workspace.name %></span>
        <% end %>
        <%= nav_link_to "Settings", settings_path, mobile: true %>
        <div class="border-t border-gray-200 mt-2 pt-2">
          <span class="block px-3 py-1 text-sm text-gray-500"><%= Current.user.name %></span>
          <%= button_to "Sign out", session_path, method: :delete,
              class: "w-full text-left px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50 cursor-pointer" %>
        </div>
      <% else %>
        <%= link_to "Sign in", new_session_path,
            class: "block px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50" %>
        <%= link_to "Sign up", new_registration_path,
            class: "block px-3 py-2 rounded-lg text-sm font-medium bg-brand-600 text-white hover:bg-brand-500 text-center" %>
      <% end %>
    </div>
  </div>
</nav>
