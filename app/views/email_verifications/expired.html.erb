<% content_for :title, "Email Verification Required — MapWise" %>

<div class="flex items-center justify-center min-h-[60vh]">
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-8 max-w-md w-full text-center">
    <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-red-100 mb-4">
      <svg class="h-6 w-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
      </svg>
    </div>

    <h1 class="text-xl font-semibold text-gray-900 mb-2">Email verification required</h1>
    <p class="text-gray-600 mb-6">
      Your email verification deadline has passed. Please verify your email address to continue using MapWise.
    </p>

    <%= button_to "Resend verification email", resend_email_verification_path, method: :post,
        class: "inline-flex items-center justify-center rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 w-full mb-3" %>

    <%= link_to "Sign out", session_path, data: { turbo_method: :delete },
        class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>
</div>
