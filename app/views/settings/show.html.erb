<div class="max-w-2xl mx-auto" data-controller="tabs">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Settings</h1>
  </div>

  <%# Tabs %>
  <div class="border-b border-gray-200 mb-6">
    <nav class="flex gap-4 -mb-px">
      <button data-tabs-target="tab" data-action="click->tabs#select"
              class="px-1 pb-3 text-sm font-medium border-b-2 cursor-pointer">
        Profile
      </button>
      <button data-tabs-target="tab" data-action="click->tabs#select"
              class="px-1 pb-3 text-sm font-medium border-b-2 cursor-pointer">
        Google Maps
      </button>
    </nav>
  </div>

  <%# Profile tab %>
  <div data-tabs-target="panel">
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
      <h2 class="font-bold text-lg mb-4">Profile</h2>

      <%= form_with model: @user, url: settings_path, method: :patch do |form| %>
        <% if @user.errors.any? %>
          <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
            <ul class="list-disc ml-5">
              <% @user.errors.each do |error| %>
                <li><%= error.full_message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="space-y-4">
          <div>
            <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= form.text_field :name, class: "block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2 text-sm focus:bg-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none" %>
          </div>

          <div>
            <%= form.label :email_address, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= form.email_field :email_address, class: "block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2 text-sm focus:bg-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none" %>
          </div>

          <%= form.submit "Save Changes", class: "rounded-lg px-4 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium cursor-pointer transition-colors" %>
        </div>
      <% end %>
    </div>
  </div>

  <%# Google Maps tab %>
  <div data-tabs-target="panel" class="hidden">
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
      <h2 class="font-bold text-lg mb-4">Google Maps API Key</h2>
      <p class="text-gray-600 mb-4 text-sm">Your Google Maps API key is used for map embedding on external sites. Maps inside <%= app_name %> work without it.</p>

      <% api_key = @api_key %>
      <%= form_with model: api_key, url: api_key.persisted? ? api_key_path(api_key) : api_keys_path, method: api_key.persisted? ? :patch : :post do |form| %>
        <% if api_key.errors.any? %>
          <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
            <ul class="list-disc ml-5">
              <% api_key.errors.each do |error| %>
                <li><%= error.full_message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="space-y-4">
          <div>
            <%= form.label :google_maps_key, "API Key", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= form.text_field :google_maps_key, required: true, placeholder: "AIzaSy...", class: "block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2 text-sm font-mono focus:bg-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none" %>
          </div>

          <div class="flex items-center gap-3">
            <%= form.submit api_key.persisted? ? "Update Key" : "Save Key", class: "rounded-lg px-4 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium cursor-pointer transition-colors" %>

            <% if api_key.persisted? %>
              <button type="button"
                      data-action="click->confirm-dialog#open"
                      data-confirm-title="Remove Google Maps API key"
                      data-confirm-message="Remove your API key? Embedded maps will stop working."
                      data-confirm-form="#delete_api_key"
                      class="text-red-600 hover:text-red-800 text-sm font-medium cursor-pointer">
                Remove Key
              </button>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if api_key.persisted? %>
        <%= form_with url: api_key_path(api_key), method: :delete, id: "delete_api_key", class: "hidden" do %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
