<div id="marker_<%= marker.id %>">
  <div data-role="content" class="flex items-center justify-between px-3 py-2 rounded-md hover:bg-gray-50 group">
    <div class="flex items-center gap-2 min-w-0">
      <span class="w-3 h-3 rounded-full shrink-0" style="background-color: <%= marker.color %>"></span>
      <span class="text-sm font-medium truncate"><%= marker.title.presence || "Untitled Marker" %></span>
    </div>
    <div class="flex items-center gap-2 shrink-0 opacity-0 group-hover:opacity-100">
      <% if marker.marker_group_id.present? %>
        <a href="#" data-action="click->marker-editor#ungroupMarker"
           data-marker-editor-id-param="<%= marker.id %>"
           class="text-gray-500 hover:text-gray-700 text-xs font-medium cursor-pointer"
           title="Remove from group">Ungroup</a>
      <% end %>
      <%= link_to "Edit", edit_map_marker_path(marker.map, marker),
          data: { turbo_frame: "marker_form" },
          class: "text-blue-600 hover:text-blue-800 text-xs font-medium" %>
      <a href="#" data-action="click->marker-editor#deleteMarker"
         data-marker-editor-id-param="<%= marker.id %>"
         class="text-red-600 hover:text-red-800 text-xs font-medium cursor-pointer">Delete</a>
    </div>
  </div>
  <div data-role="confirm" class="hidden flex items-center justify-between px-3 py-2 bg-red-50 rounded-md">
    <span class="text-sm text-red-700 font-medium">Delete marker?</span>
    <div class="flex gap-2">
      <button data-action="click->marker-editor#cancelDelete"
              class="text-xs font-medium text-gray-600 hover:text-gray-800 cursor-pointer">Cancel</button>
      <button data-action="click->marker-editor#confirmDeleteMarker"
              data-marker-editor-id-param="<%= marker.id %>"
              class="text-xs font-medium text-white bg-red-600 hover:bg-red-500 rounded-md px-2.5 py-1 cursor-pointer">Delete</button>
    </div>
  </div>
</div>
