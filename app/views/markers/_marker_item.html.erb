<div id="marker_<%= marker.id %>" class="flex items-center justify-between p-2 rounded-md hover:bg-gray-50 group">
  <div class="flex items-center gap-2 min-w-0">
    <span class="w-3 h-3 rounded-full shrink-0" style="background-color: <%= marker.color %>"></span>
    <span class="text-sm font-medium truncate"><%= marker.title.presence || "Untitled Marker" %></span>
  </div>
  <div class="flex items-center gap-2 shrink-0 opacity-0 group-hover:opacity-100">
    <%= link_to "Edit", edit_map_marker_path(marker.map, marker),
        data: { turbo_frame: "marker_form" },
        class: "text-blue-600 hover:text-blue-800 text-xs font-medium" %>
    <a href="#" data-action="click->marker-editor#deleteMarker"
       data-marker-editor-id-param="<%= marker.id %>"
       class="text-red-600 hover:text-red-800 text-xs font-medium cursor-pointer">Delete</a>
  </div>
</div>
