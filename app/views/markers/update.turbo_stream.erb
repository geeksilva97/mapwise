<%= turbo_stream.replace @marker do %>
  <%= render "markers/marker_item", marker: @marker %>
<% end %>

<%= turbo_stream.replace "marker_form" do %>
  <turbo-frame id="marker_form"></turbo-frame>
<% end %>

<%= turbo_stream.append "map-canvas" do %>
  <template data-map-target="markerSync"
            data-markers="<%= @map.markers.select(:id, :lat, :lng, :title, :description, :color, :marker_group_id, :custom_info_html).to_json %>">
  </template>
<% end %>
