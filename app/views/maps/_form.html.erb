<%= form_with model: map, id: "map_settings_form" do |form| %>
  <% if map.errors.any? %>
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
      <ul class="list-disc ml-5">
        <% map.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-4">
    <div>
      <%= form.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :title, required: true, autofocus: true, placeholder: "My Map", class: "block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2 text-sm focus:bg-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none" %>
    </div>

    <div>
      <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_area :description, rows: 3, placeholder: "Optional description", class: "block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2 text-sm focus:bg-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none" %>
    </div>

    <% unless map.new_record? %>
      <div class="border-t border-gray-200 pt-4 mt-2">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-3">Display options</p>
        <label class="flex items-center gap-2.5 cursor-pointer">
          <%= form.check_box :clustering_enabled, class: "h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500/20" %>
          <span class="text-sm font-medium text-gray-700">Enable marker clustering</span>
        </label>
        <p class="text-xs text-gray-400 mt-1 ml-6.5">Groups nearby markers into clusters when zoomed out.</p>
      </div>

      <div class="border-t border-gray-200 pt-4 mt-2">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-3">Starting position</p>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <%= form.label :center_lat, "Latitude", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= form.number_field :center_lat, step: "any", required: true, placeholder: "39.8283", class: "block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2 text-sm focus:bg-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none" %>
          </div>

          <div>
            <%= form.label :center_lng, "Longitude", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= form.number_field :center_lng, step: "any", required: true, placeholder: "-98.5795", class: "block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2 text-sm focus:bg-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none" %>
          </div>
        </div>

        <div class="mt-3">
          <%= form.label :zoom, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.number_field :zoom, min: 1, max: 22, step: 1, required: true, class: "block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2 text-sm focus:bg-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none" %>
          <p class="text-xs text-gray-400 mt-1">1 (world) to 22 (street level)</p>
        </div>

        <button type="button"
                data-action="click->marker-editor#capturePosition"
                class="mt-3 inline-flex items-center gap-1.5 rounded-lg px-3 py-1.5 border border-gray-300 hover:bg-gray-50 text-sm font-medium text-gray-700 cursor-pointer transition-colors">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
          Use current view
        </button>
        <p class="text-xs text-gray-400 mt-2">Captures the map's current center and zoom level.</p>
      </div>
    <% end %>

    <div class="flex items-center gap-3">
      <%= form.submit class: "rounded-lg px-4 py-2.5 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium cursor-pointer transition-colors" %>
      <div id="settings_feedback"></div>
    </div>
  </div>
<% end %>
