<div class="h-screen flex flex-col">
  <header class="bg-white border-b px-4 py-3 flex items-center justify-between shrink-0">
    <div class="flex items-center gap-3">
      <%= link_to root_path, class: "text-gray-400 hover:text-blue-600 transition-colors" do %>
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
        </svg>
      <% end %>
      <div>
        <h1 class="font-bold text-lg"><%= @map.title %></h1>
        <% if @map.description.present? %>
          <p class="text-sm text-gray-500"><%= @map.description %></p>
        <% end %>
      </div>
    </div>
    <div class="flex gap-2">
      <%= link_to edit_map_path(@map), class: "inline-flex items-center gap-1.5 rounded-lg px-3 py-1.5 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium transition-colors" do %>
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125" />
        </svg>
        Edit
      <% end %>
      <%= link_to root_path, class: "inline-flex items-center gap-1.5 rounded-lg px-3 py-1.5 border border-gray-300 hover:bg-gray-50 text-sm font-medium transition-colors" do %>
        Back
      <% end %>
    </div>
  </header>

  <div id="map-canvas"
       data-controller="map"
       data-map-api-key-value="<%= platform_api_key %>"
       data-map-center-lat-value="<%= @map.center_lat %>"
       data-map-center-lng-value="<%= @map.center_lng %>"
       data-map-zoom-value="<%= @map.zoom %>"
       data-map-readonly-value="true"
       class="flex-1">
  </div>
</div>
