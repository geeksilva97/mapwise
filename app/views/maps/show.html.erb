<div class="h-screen flex flex-col">
  <header class="bg-white border-b px-4 py-3 flex items-center justify-between">
    <div>
      <h1 class="font-bold text-xl"><%= @map.title %></h1>
      <% if @map.description.present? %>
        <p class="text-sm text-gray-500 mt-1"><%= @map.description %></p>
      <% end %>
    </div>
    <div class="flex gap-3">
      <%= link_to "Edit", edit_map_path(@map), class: "rounded-md px-3 py-1.5 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium" %>
      <%= link_to "Back", root_path, class: "rounded-md px-3 py-1.5 border border-gray-300 hover:bg-gray-50 text-sm font-medium" %>
    </div>
  </header>

  <div id="map-canvas"
       data-controller="map"
       data-map-api-key-value="<%= platform_api_key %>"
       data-map-center-lat-value="<%= @map.center_lat %>"
       data-map-center-lng-value="<%= @map.center_lng %>"
       data-map-zoom-value="<%= @map.zoom %>"
       data-map-readonly-value="true"
       class="flex-1">
  </div>
</div>
