<div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden hover:shadow-md transition-shadow">
  <div class="h-40 bg-gradient-to-br from-blue-50 to-blue-100 flex items-center justify-center">
    <svg class="h-12 w-12 text-blue-300" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
    </svg>
  </div>

  <div class="p-4">
    <div class="flex items-start justify-between">
      <div class="min-w-0 flex-1">
        <h3 class="font-bold text-lg text-gray-900 truncate"><%= map.title %></h3>
        <% if map.description.present? %>
          <p class="text-sm text-gray-500 mt-1 line-clamp-2"><%= map.description %></p>
        <% end %>
      </div>
      <% if map.public? %>
        <span class="ml-2 shrink-0 inline-flex items-center text-xs font-medium bg-green-50 text-green-700 px-2 py-0.5 rounded-full border border-green-200">Public</span>
      <% else %>
        <span class="ml-2 shrink-0 inline-flex items-center text-xs font-medium bg-gray-50 text-gray-600 px-2 py-0.5 rounded-full border border-gray-200">Private</span>
      <% end %>
    </div>

    <div class="flex items-center justify-between mt-4 pt-3 border-t border-gray-100">
      <div class="text-xs text-gray-400">
        <span><%= map.markers_count %> markers</span>
        <span class="mx-1">&middot;</span>
        <span>Updated <%= time_ago_in_words(map.updated_at) %> ago</span>
      </div>

      <div class="flex gap-1">
        <%= link_to edit_map_path(map), class: "inline-flex items-center gap-1 px-2.5 py-1.5 rounded-lg text-sm font-medium text-blue-600 hover:bg-blue-50 transition-colors" do %>
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125" />
          </svg>
          Edit
        <% end %>
        <%= link_to map_path(map), class: "inline-flex items-center gap-1 px-2.5 py-1.5 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50 transition-colors" do %>
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          View
        <% end %>
      </div>
    </div>
  </div>
</div>
