<div class="h-screen flex flex-col"
     data-controller="marker-editor"
     data-marker-editor-map-id-value="<%= @map.id %>">

  <header class="bg-white border-b px-4 py-3 flex items-center justify-between shrink-0">
    <div class="flex items-center gap-3">
      <%= link_to root_path, class: "text-gray-400 hover:text-blue-600 transition-colors" do %>
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
        </svg>
      <% end %>
      <h1 class="font-bold text-lg"><%= @map.title %></h1>
    </div>
    <div class="flex gap-2">
      <%= link_to root_path, class: "inline-flex items-center gap-1.5 rounded-lg px-3 py-1.5 border border-gray-300 hover:bg-gray-50 text-sm font-medium transition-colors" do %>
        Dashboard
      <% end %>
      <%= link_to map_path(@map), class: "inline-flex items-center gap-1.5 rounded-lg px-3 py-1.5 border border-gray-300 hover:bg-gray-50 text-sm font-medium transition-colors" do %>
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        View
      <% end %>
    </div>
  </header>

  <div class="flex flex-1 overflow-hidden">
    <%# Sidebar %>
    <aside class="w-80 border-r bg-white flex flex-col shrink-0" data-controller="tabs">
      <%# Tab navigation %>
      <nav class="flex border-b shrink-0">
        <button data-tabs-target="tab" data-action="click->tabs#select"
                class="flex-1 py-3 text-sm font-medium text-center border-b-2 border-blue-600 text-blue-600">
          Markers
        </button>
        <button data-tabs-target="tab" data-action="click->tabs#select"
                class="flex-1 py-3 text-sm font-medium text-center border-b-2 border-transparent text-gray-500 hover:text-gray-700">
          Import
        </button>
        <button data-tabs-target="tab" data-action="click->tabs#select"
                class="flex-1 py-3 text-sm font-medium text-center border-b-2 border-transparent text-gray-500 hover:text-gray-700">
          Settings
        </button>
      </nav>

      <%# Markers panel %>
      <div data-tabs-target="panel" class="flex-1 overflow-y-auto p-4">
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-bold text-lg">Markers (<span data-marker-editor-target="count"><%= @map.markers.count %></span>)</h2>
          <button data-marker-editor-target="addButton"
                  data-action="click->marker-editor#togglePlacementMode"
                  class="rounded-md px-3 py-1.5 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium cursor-pointer">
            + Add
          </button>
        </div>

        <div data-marker-editor-target="placementBanner" class="hidden mb-3 rounded-lg bg-blue-50 border border-blue-200 px-3 py-2">
          <p class="text-sm text-blue-700 font-medium">Click on the map to place a marker</p>
        </div>

        <div data-marker-editor-target="circleSelectionBanner" class="hidden mb-3 rounded-lg bg-indigo-50 border border-indigo-200 px-3 py-2">
          <p class="text-sm text-indigo-700 font-medium">Draw a circle on the map to select markers</p>
        </div>

        <%# Ungrouped markers %>
        <div id="markers_list" class="space-y-1 mb-4">
          <% @map.markers.where(marker_group_id: nil).order(:position).each do |marker| %>
            <%= render "markers/marker_item", marker: marker %>
          <% end %>
        </div>

        <% if @map.markers.empty? %>
          <p id="markers_empty" class="text-sm text-gray-500 mt-2">Click "+ Add" then click on the map to place a marker.</p>
        <% end %>

        <turbo-frame id="marker_form"></turbo-frame>

        <%# Groups section %>
        <div class="border-t border-gray-200 pt-4 mt-4"
             data-controller="group">
          <div class="flex items-center justify-between mb-3">
            <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Groups</p>
            <button type="button"
                    data-action="click->group#showNewForm"
                    class="text-xs text-blue-600 hover:text-blue-800 font-medium cursor-pointer">
              + New Group
            </button>
          </div>

          <div id="new_group_form_container"></div>

          <div id="groups_list" class="space-y-2">
            <% @map.marker_groups.ordered.each do |group| %>
              <%= render "marker_groups/group_section", map: @map, group: group %>
            <% end %>
          </div>

          <% if @map.marker_groups.empty? %>
            <p id="groups_empty" class="text-sm text-gray-400">No groups yet. Create a group to organize markers.</p>
          <% end %>
        </div>

        <%# Layers section %>
        <div class="border-t border-gray-200 pt-4 mt-4">
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-3">Layers</p>

          <div id="layers_list" class="space-y-1">
            <% @map.layers.ordered.each do |layer| %>
              <%= render "layers/layer_item", layer: layer %>
            <% end %>
          </div>

          <% if @map.layers.empty? %>
            <p id="layers_empty" class="text-sm text-gray-400 mt-2">Use the drawing tools on the map to add shapes.</p>
          <% end %>
        </div>
      </div>

      <%# Import panel %>
      <div data-tabs-target="panel" class="flex-1 overflow-y-auto p-4 hidden">
        <h2 class="font-bold text-lg mb-4">Import Data</h2>
        <%= render "imports/upload", map: @map %>
      </div>

      <%# Settings panel %>
      <div data-tabs-target="panel" class="flex-1 overflow-y-auto p-4 hidden">
        <h2 class="font-bold text-lg mb-4">Map Settings</h2>
        <%= render "form", map: @map %>

        <div class="border-t border-gray-200 pt-4 mt-4"
             data-controller="style-picker"
             data-style-picker-map-id-value="<%= @map.id %>">
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-3">Map style</p>
          <%= render "map_styles/picker", styles: MapStyle.for_user(Current.user), map: @map %>
          <p class="text-xs text-gray-400 mt-2">Applies immediately. <% if MapStyle.for_user(Current.user).where(system_default: false).any? %>Manage styles in <%= link_to "Map Styles", map_styles_path, class: "text-blue-600 hover:text-blue-800 underline" %>.<% end %></p>
        </div>

        <div class="border-t border-gray-200 pt-4 mt-4"
             data-controller="share"
             data-share-map-id-value="<%= @map.id %>">
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-3">Sharing</p>

          <label class="flex items-center gap-2.5 cursor-pointer">
            <input type="checkbox"
                   data-share-target="toggle"
                   data-action="change->share#togglePublic"
                   <%= "checked" if @map.public? %>
                   class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500/20">
            <span class="text-sm font-medium text-gray-700">Public map</span>
          </label>
          <p class="text-xs text-gray-400 mt-1.5 ml-6.5">Public maps can be embedded on external websites.</p>
          <p data-share-target="status" class="hidden text-xs font-medium text-green-600 mt-1.5 ml-6.5"></p>

          <div data-share-target="embedSection" class="<%= 'hidden' unless @map.public? %> mt-4 space-y-3">
            <% if Current.user.api_keys.any? %>
              <div>
                <label class="block text-xs font-medium text-gray-500 mb-1">Embed code</label>
                <div class="flex gap-1.5">
                  <input type="text" readonly
                         data-share-target="embedCode"
                         value='<iframe src="<%= embed_url(@map.embed_token) %>" width="100%" height="400" frameborder="0"></iframe>'
                         class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-2.5 py-1.5 text-xs text-gray-600 font-mono focus:bg-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none">
                  <button type="button"
                          data-action="click->share#copyEmbed"
                          class="shrink-0 rounded-lg px-2.5 py-1.5 border border-gray-300 hover:bg-gray-50 text-xs font-medium text-gray-700 cursor-pointer transition-colors">
                    Copy
                  </button>
                </div>
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-500 mb-1">Direct link</label>
                <div class="flex gap-1.5">
                  <input type="text" readonly
                         data-share-target="directLink"
                         value="<%= embed_url(@map.embed_token) %>"
                         class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-2.5 py-1.5 text-xs text-gray-600 font-mono focus:bg-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none">
                  <button type="button"
                          data-action="click->share#copyLink"
                          class="shrink-0 rounded-lg px-2.5 py-1.5 border border-gray-300 hover:bg-gray-50 text-xs font-medium text-gray-700 cursor-pointer transition-colors">
                    Copy
                  </button>
                </div>
              </div>
            <% else %>
              <div class="rounded-lg bg-amber-50 border border-amber-200 px-3 py-2.5">
                <p class="text-sm text-amber-800">To enable embedding, add a Google Maps API key in <%= link_to "API Keys", api_keys_path, class: "font-medium text-amber-900 underline" %>.</p>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </aside>

    <%# Map canvas with drawing controller %>
    <div class="flex-1 relative"
         data-controller="drawing"
         data-drawing-map-id-value="<%= @map.id %>"
         data-drawing-readonly-value="false"
         data-drawing-layers-value="<%= @map.layers.visible.ordered.to_json(only: [:id, :name, :layer_type, :geometry_data, :stroke_color, :stroke_width, :fill_color, :fill_opacity, :visible]) %>">

      <%# Drawing toolbar %>
      <div data-drawing-target="toolbar"
           class="absolute top-3 left-3 z-10 flex gap-1 bg-white rounded-lg shadow-md border border-gray-200 p-1">
        <button type="button" data-action="click->drawing#drawPolygon" data-mode="polygon"
                class="p-2 rounded hover:bg-gray-100 transition-colors" title="Draw polygon">
          <svg class="h-5 w-5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6z" />
          </svg>
        </button>
        <button type="button" data-action="click->drawing#drawLine" data-mode="linestring"
                class="p-2 rounded hover:bg-gray-100 transition-colors" title="Draw line">
          <svg class="h-5 w-5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75l16.5 16.5" />
          </svg>
        </button>
        <button type="button" data-action="click->drawing#drawCircle" data-mode="circle"
                class="p-2 rounded hover:bg-gray-100 transition-colors" title="Draw circle">
          <svg class="h-5 w-5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <circle cx="12" cy="12" r="9" />
          </svg>
        </button>
        <button type="button" data-action="click->drawing#drawRectangle" data-mode="rectangle"
                class="p-2 rounded hover:bg-gray-100 transition-colors" title="Draw rectangle">
          <svg class="h-5 w-5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <rect x="3.75" y="5.25" width="16.5" height="13.5" rx="1" />
          </svg>
        </button>
        <button type="button" data-action="click->drawing#drawFreehand" data-mode="freehand"
                class="p-2 rounded hover:bg-gray-100 transition-colors" title="Draw freehand">
          <svg class="h-5 w-5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" />
          </svg>
        </button>
        <div class="w-px bg-gray-200 mx-0.5"></div>
        <button type="button" data-action="click->drawing#selectMode" data-mode="select"
                class="p-2 rounded hover:bg-gray-100 transition-colors" title="Select & edit">
          <svg class="h-5 w-5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.042 21.672L13.684 16.6m0 0l-2.51 2.225.569-9.47 5.227 7.917-3.286-.672zM12 2.25V4.5m5.834.166l-1.591 1.591M20.25 10.5H18M7.757 14.743l-1.59 1.59M6 10.5H3.75m4.007-4.243l-1.59-1.59" />
          </svg>
        </button>
        <button type="button" data-action="click->drawing#cancelDrawing" data-mode="render"
                class="p-2 rounded hover:bg-gray-100 transition-colors" title="Cancel drawing">
          <svg class="h-5 w-5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <div id="map-canvas"
           data-controller="map"

           data-map-center-lat-value="<%= @map.center_lat %>"
           data-map-center-lng-value="<%= @map.center_lng %>"
           data-map-zoom-value="<%= @map.zoom %>"
           data-map-id-value="<%= @map.id %>"
           data-map-readonly-value="false"
           data-map-markers-value="<%= @map.markers.select(:id, :lat, :lng, :title, :description, :color, :marker_group_id, :custom_info_html).to_json %>"
           data-map-groups-value="<%= @map.marker_groups.ordered.to_json(only: [:id, :name, :color, :visible]) %>"
           data-map-clustering-enabled-value="<%= @map.clustering_enabled? %>"
           <% if @map.style_json.present? %>
             data-map-style-json-value="<%= @map.style_json %>"
           <% end %>
           <% if @map.google_map_id.present? %>
             data-map-google-map-id-value="<%= @map.google_map_id %>"
           <% end %>
           data-action="map:markerPlaced->marker-editor#placed map:markerDragged->marker-editor#dragged map:circleSelectionStarted->marker-editor#showCircleBanner map:circleSelectionEnded->marker-editor#hideCircleBanner"
           class="absolute inset-0">
      </div>
    </div>
  </div>

</div>
