<div class="h-screen flex flex-col"
     data-controller="marker-editor"
     data-marker-editor-map-id-value="<%= @map.id %>">

  <header class="bg-white border-b px-4 py-3 flex items-center justify-between shrink-0">
    <div class="flex items-center gap-3">
      <%= link_to "← Back", root_path, class: "text-gray-500 hover:text-gray-700 text-sm" %>
      <h1 class="font-bold text-xl"><%= @map.title %></h1>
    </div>
    <div class="flex gap-3">
      <%= link_to "View", map_path(@map), class: "rounded-md px-3 py-1.5 border border-gray-300 hover:bg-gray-50 text-sm font-medium" %>
    </div>
  </header>

  <div class="flex flex-1 overflow-hidden">
    <%# Sidebar %>
    <aside class="w-80 border-r bg-white flex flex-col shrink-0" data-controller="tabs">
      <%# Tab navigation %>
      <nav class="flex border-b shrink-0">
        <button data-tabs-target="tab" data-action="click->tabs#select"
                class="flex-1 py-3 text-sm font-medium text-center border-b-2 border-blue-600 text-blue-600">
          Markers
        </button>
        <button data-tabs-target="tab" data-action="click->tabs#select"
                class="flex-1 py-3 text-sm font-medium text-center border-b-2 border-transparent text-gray-500 hover:text-gray-700">
          Styles
        </button>
        <button data-tabs-target="tab" data-action="click->tabs#select"
                class="flex-1 py-3 text-sm font-medium text-center border-b-2 border-transparent text-gray-500 hover:text-gray-700">
          Settings
        </button>
      </nav>

      <%# Markers panel %>
      <div data-tabs-target="panel" class="flex-1 overflow-y-auto p-4">
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-bold text-lg">Markers (<span id="marker_count"><%= @map.markers.count %></span>)</h2>
          <button data-action="click->map#enterPlacementMode"
                  class="rounded-md px-3 py-1.5 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium">
            + Add
          </button>
        </div>

        <div id="markers_list" class="space-y-1">
          <% @map.markers.order(:position).each do |marker| %>
            <%= render "markers/marker_item", marker: marker %>
          <% end %>
        </div>

        <% if @map.markers.empty? %>
          <p id="markers_empty" class="text-sm text-gray-500 mt-2">Click "+ Add" then click on the map to place a marker.</p>
        <% end %>

        <turbo-frame id="marker_form"></turbo-frame>
      </div>

      <%# Styles panel %>
      <div data-tabs-target="panel" class="flex-1 overflow-y-auto p-4 hidden"
           data-controller="style-picker"
           data-style-picker-map-id-value="<%= @map.id %>">
        <h2 class="font-bold text-lg mb-4">Styles</h2>
        <%= render "map_styles/picker", styles: MapStyle.for_user(Current.user), map: @map %>
      </div>

      <%# Settings panel %>
      <div data-tabs-target="panel" class="flex-1 overflow-y-auto p-4 hidden">
        <h2 class="font-bold text-lg mb-4">Map Settings</h2>
        <%= render "form", map: @map %>
      </div>
    </aside>

    <%# Map canvas %>
    <div id="map-canvas"
         data-controller="map"
         data-map-api-key-value="<%= platform_api_key %>"
         data-map-center-lat-value="<%= @map.center_lat %>"
         data-map-center-lng-value="<%= @map.center_lng %>"
         data-map-zoom-value="<%= @map.zoom %>"
         data-map-id-value="<%= @map.id %>"
         data-map-readonly-value="false"
         data-map-markers-value="<%= @map.markers.select(:id, :lat, :lng, :title, :description, :color).to_json %>"
         data-action="map:markerPlaced->marker-editor#placed map:markerDragged->marker-editor#dragged"
         class="flex-1">
    </div>
  </div>

  <%# Markers data for JS synchronization %>
  <script type="application/json" id="markers-data">
    <%= @map.markers.select(:id, :lat, :lng, :title, :description, :color).to_json.html_safe %>
  </script>
</div>
