<div class="max-w-2xl mx-auto">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Map Styles</h1>
  </div>

  <div class="space-y-3">
    <% @styles.each do |style| %>
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 flex items-center justify-between">
        <div>
          <p class="font-medium"><%= style.name %></p>
          <% if style.system_default? %>
            <span class="text-xs text-gray-400">System preset</span>
          <% end %>
        </div>
        <% unless style.system_default? %>
          <%= button_to "Delete", map_style_path(style), method: :delete,
              class: "text-red-600 hover:text-red-800 text-sm font-medium cursor-pointer",
              data: { turbo_confirm: "Delete this style?" } %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
