<%= form_with model: api_key, url: api_keys_path do |form| %>
  <% if api_key.errors.any? %>
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
      <ul class="list-disc ml-5">
        <% api_key.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-4">
    <div>
      <%= form.label :label, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :label, placeholder: "Default", class: "block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2 text-sm focus:bg-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none" %>
    </div>

    <div>
      <%= form.label :google_maps_key, "Google Maps API Key", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :google_maps_key, required: true, placeholder: "AIzaSy...", class: "block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2 text-sm font-mono focus:bg-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none" %>
    </div>

    <%= form.submit "Save API Key", class: "rounded-lg px-4 py-2.5 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium cursor-pointer transition-colors" %>
  </div>
<% end %>
