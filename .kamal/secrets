RAILS_MASTER_KEY=$(cat config/master.key)

# Source all deployment config from .env
set -a; source .env 2>/dev/null; set +a

# Registry auth — override KAMAL_REGISTRY_PASSWORD in .env for non-GCP registries
KAMAL_REGISTRY_PASSWORD=${KAMAL_REGISTRY_PASSWORD:-$(gcloud auth print-access-token 2>/dev/null)}
