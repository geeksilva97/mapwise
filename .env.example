# ===========================================
# Self-Hosting Configuration
# ===========================================
# Copy this file to .env and fill in your values.
# .env is gitignored and will not be committed.
#
# See README.md for full documentation.

# --- Branding (optional, defaults shown) ---
# APP_NAME=MapWise
# MAILER_FROM_ADDRESS=noreply@example.com
# THEME_COLOR=#2563eb

# --- AI (optional) ---
# RUBY_LLM_MODEL=                   # Default: Claude Sonnet. Options: gpt-4o, gemini-2.0-flash, etc.

# --- Email ---
# MAILER_HOST=                       # Your domain or IP (used in email links)

# --- Performance ---
# WEB_CONCURRENCY=2
# RAILS_MAX_THREADS=5
# RAILS_LOG_LEVEL=info

# --- Deployment (Kamal 2) ---
DEPLOY_HOST=                          # Server IP or hostname (required)
DEPLOY_SERVICE=mapwise               # Kamal service name
DEPLOY_IMAGE=mapwise                 # Container image (e.g. ghcr.io/you/mapwise)
DEPLOY_REGISTRY=                      # Registry server (e.g. ghcr.io, docker.io)
DEPLOY_REGISTRY_USERNAME=            # Registry auth username
DEPLOY_SSH_USER=root                 # SSH user with Docker access
# DEPLOY_SSH_KEY=~/.ssh/id_rsa      # SSH private key path (omit for default)
DEPLOY_VOLUME=mapwise_storage        # Docker volume for SQLite + uploads

# --- Registry auth ---
# KAMAL_REGISTRY_PASSWORD=           # Set this, or let .kamal/secrets auto-detect for GCP
