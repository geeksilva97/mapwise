  "delivery_route" => {
    description: "Local neighborhood delivery loop with stops (Brooklyn)",
    waypoints: [
      [40.6892, -73.9857, 0],   # Stop 1 — Warehouse
      [40.6895, -73.9850, 10],
      [40.6905, -73.9835, 20],
      [40.6920, -73.9815, 25],
      [40.6935, -73.9800, 20],
      [40.6945, -73.9790, 0],   # Stop 2 — Delivery
