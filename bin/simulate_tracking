#!/usr/bin/env ruby
# frozen_string_literal: true

# Standalone tracking simulator — no Rails dependency.
# Sends realistic GPS coordinates to the webhook endpoint so you can
# demo vehicle movement on the live tracking page.
#
# Usage:
#   bin/simulate_tracking <WEBHOOK_TOKEN>
#   bin/simulate_tracking <WEBHOOK_TOKEN> --route highway_drive --interval 1
#   bin/simulate_tracking <WEBHOOK_TOKEN> --loop
#   bin/simulate_tracking --list

require "net/http"
require "json"
require "uri"
require "optparse"

# ---------------------------------------------------------------------------
# Predefined routes: arrays of [lat, lng, speed_kmh]
# ---------------------------------------------------------------------------
ROUTES = {
  "nyc_taxi" => {
    description: "Cab through Manhattan: Times Square → Central Park → Upper East Side → East Village",
    waypoints: [
      [40.7580, -73.9855, 15],  # Times Square
      [40.7590, -73.9845, 25],
      [40.7614, -73.9818, 30],
      [40.7641, -73.9794, 35],
      [40.7668, -73.9763, 30],  # Heading toward Central Park
      [40.7695, -73.9740, 25],
      [40.7712, -73.9742, 20],
      [40.7735, -73.9755, 15],  # Central Park South
      [40.7751, -73.9712, 20],
      [40.7790, -73.9680, 30],
      [40.7812, -73.9650, 35],  # Inside Central Park area
      [40.7835, -73.9620, 30],
      [40.7815, -73.9590, 25],  # Turning east
      [40.7790, -73.9560, 30],
