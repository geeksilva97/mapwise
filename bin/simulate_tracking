      [40.6910, -73.9860, 10],
      [40.6892, -73.9857, 0],   # Back to warehouse
    ]
  }
}.freeze

# ---------------------------------------------------------------------------
# Geo math
# ---------------------------------------------------------------------------
DEG_TO_RAD = Math::PI / 180.0
RAD_TO_DEG = 180.0 / Math::PI
EARTH_RADIUS_M = 6_371_000.0

def haversine_distance(lat1, lng1, lat2, lng2)
  dlat = (lat2 - lat1) * DEG_TO_RAD
  dlng = (lng2 - lng1) * DEG_TO_RAD
  a = Math.sin(dlat / 2)**2 +
      Math.cos(lat1 * DEG_TO_RAD) * Math.cos(lat2 * DEG_TO_RAD) *
      Math.sin(dlng / 2)**2
  2.0 * EARTH_RADIUS_M * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a))
end

def bearing(lat1, lng1, lat2, lng2)
  dl = (lng2 - lng1) * DEG_TO_RAD
  la1 = lat1 * DEG_TO_RAD
  la2 = lat2 * DEG_TO_RAD
  x = Math.sin(dl) * Math.cos(la2)
  y = Math.cos(la1) * Math.sin(la2) - Math.sin(la1) * Math.cos(la2) * Math.cos(dl)
  (Math.atan2(x, y) * RAD_TO_DEG + 360) % 360
end

# ---------------------------------------------------------------------------
# Interpolation — expand waypoints into ~step_meters apart points
# ---------------------------------------------------------------------------
def interpolate(waypoints, step_meters = 50)
  points = []

  waypoints.each_cons(2) do |(lat1, lng1, spd1), (lat2, lng2, spd2)|
    dist = haversine_distance(lat1, lng1, lat2, lng2)
    steps = [1, (dist / step_meters).ceil].max

    steps.times do |i|
      t = i.to_f / steps
      lat = lat1 + (lat2 - lat1) * t
      lng = lng1 + (lng2 - lng1) * t
      spd = spd1 + (spd2 - spd1) * t
      points << { lat: lat.round(6), lng: lng.round(6), speed: spd.round(1) }
    end
  end

  # Add the final waypoint
  last = waypoints.last
  points << { lat: last[0].round(6), lng: last[1].round(6), speed: last[2].round(1) }

  # Compute headings from consecutive points
  points.each_cons(2) do |a, b|
    a[:heading] = bearing(a[:lat], a[:lng], b[:lat], b[:lng]).round(1)
  end
  points.last[:heading] = points[-2][:heading] if points.size > 1
  points.last[:heading] ||= 0.0

  points
end

# ---------------------------------------------------------------------------
# HTTP
# ---------------------------------------------------------------------------
def send_point(uri, point)
  http = Net::HTTP.new(uri.host, uri.port)
  http.use_ssl = (uri.scheme == "https")
  http.open_timeout = 5
  http.read_timeout = 5

  body = {
    lat: point[:lat],
    lng: point[:lng],
    speed: point[:speed],
    heading: point[:heading],
    recorded_at: Time.now.utc.strftime("%Y-%m-%dT%H:%M:%SZ")
  }.to_json

  request = Net::HTTP::Post.new(uri.path)
  request["Content-Type"] = "application/json"
  request.body = body

  response = http.request(request)
  response.code.to_i
rescue StandardError => e
  "ERR: #{e.message}"
end

# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------
options = {
  route: "nyc_taxi",
  interval: 2.0,
  host: "localhost:3000",
  loop: false,
  list: false,
  scheme: "http"
}

parser = OptionParser.new do |opts|
  opts.banner = "Usage: bin/simulate_tracking [TOKEN] [options]"
  opts.separator ""
  opts.separator "Sends simulated GPS points to a MapWise tracking webhook."
  opts.separator ""

  opts.on("--route ROUTE", "Route to simulate (default: nyc_taxi)") { |v| options[:route] = v }
  opts.on("--interval SECS", Float, "Seconds between points (default: 2)") { |v| options[:interval] = v }
  opts.on("--host HOST", "Target host:port (default: localhost:3000)") { |v| options[:host] = v }
  opts.on("--https", "Use HTTPS instead of HTTP") { options[:scheme] = "https" }
  opts.on("--loop", "Loop the route continuously") { options[:loop] = true }
  opts.on("--list", "List available routes and exit") { options[:list] = true }
  opts.on("-h", "--help", "Show this help") do
    puts opts
    exit
  end
end

parser.parse!

# --list: show routes and exit
if options[:list]
  puts "Available routes:"
  puts ""
  ROUTES.each do |id, route|
    points = interpolate(route[:waypoints])
    puts "  %-18s %s (%d points)" % [id, route[:description], points.size]
  end
  puts ""
  puts "Usage: bin/simulate_tracking <TOKEN> --route <ROUTE_ID>"
  exit
end

# Token is the first positional argument
token = ARGV.shift
unless token
  puts parser.banner
  puts "Error: webhook token is required. Pass -h for help."
  exit 1
end

route_data = ROUTES[options[:route]]
unless route_data
  puts "Error: unknown route '#{options[:route]}'. Use --list to see available routes."
  exit 1
end

points = interpolate(route_data[:waypoints])
url = "#{options[:scheme]}://#{options[:host]}/webhooks/tracking/#{token}"
uri = URI.parse(url)

puts "Tracking simulator started"
puts "  Route:    #{options[:route]} (#{points.size} points)"
puts "  Target:   #{url}"
puts "  Interval: #{options[:interval]}s"
puts "  Loop:     #{options[:loop] ? "yes" : "no"}"
puts ""

sent = 0

begin
  loop do
    points.each_with_index do |point, i|
      sent += 1
      status = send_point(uri, point)

      printf " #%-4d %9.4f, %9.4f  %5.1f km/h  heading %5.1f°  → %s\n",
             sent, point[:lat], point[:lng], point[:speed], point[:heading], status

      if status.is_a?(Integer) && status == 404
        puts "\nError: vehicle not found. Check that the webhook token is correct."
        exit 1
      end

      if status.is_a?(Integer) && status == 410
        puts "\nError: vehicle is inactive. Enable tracking for this vehicle first."
        exit 1
      end

      sleep options[:interval] unless i == points.size - 1 && !options[:loop]
    end

    break unless options[:loop]
    puts "\n  ↻ Looping route...\n\n"
  end
rescue Interrupt
  # Ctrl+C
end

puts "\nStopped. Sent #{sent}/#{options[:loop] ? '∞' : points.size} points."
